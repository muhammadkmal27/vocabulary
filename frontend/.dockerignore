# Exclude node_modules - npm ci will install fresh in container
node_modules/

# Exclude Next.js build output
.next/

# Exclude git directory
.git/
.github/

# Exclude local environment files
.env
.env.local
.env.*.local

# Exclude development logs
npm-debug.log*
yarn-debug.log*
yarn-error.log*

# Exclude TypeScript cache
*.tsbuildinfo

# Exclude test files
__tests__/
*.test.ts
*.test.tsx
*.spec.ts
*.spec.tsx
